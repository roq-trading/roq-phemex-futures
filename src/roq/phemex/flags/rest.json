{
  "name": "roq/phemex/flags/REST",
  "type": "flags",
  "prefix": "rest_",
  "values": [
    {
      "name": "uri",
      "type": "roq/io/web/URI",
      "validator": "roq/core/flags/URI",
      "default": "https://testnet-api.phemex.com",
      "description": "Exchange end-point"
    },
    {
      "name": "proxy",
      "type": "roq/io/web/URI",
      "validator": "roq/core/flags/URI",
      "description": "Proxy end-point"
    },
    {
      "name": "ping_freq",
      "type": "std/nanoseconds",
      "validator": "roq/flags/validators/TimePeriod",
      "default": "5s",
      "description": "Ping frequency"
    },
    {
      "name": "ping_path",
      "type": "std/string",
      "validator": "roq/flags/validators/Path",
      "default": "/public/time",
      "description": "Ping path"
    },
    {
      "name": "request_timeout",
      "type": "std/nanoseconds",
      "validator": "roq/flags/validators/TimePeriod",
      "default": "30s",
      "description": "Request timeout"
    },
    {
      "name": "download_orders_page_size",
      "type": "std/uint32",
      "required": true,
      "default": 500,
      "description": "Page size used when downloading orders"
    },
    {
      "name": "download_orders_begin",
      "type": "std/nanoseconds",
      "validator": "roq/flags/validators/TimePeriod",
      "default": "24h",
      "description": "Download orders since (now - begin)"
    },
    {
      "name": "download_only_active_orders",
      "type": "std/bool",
      "default": false,
      "description": "Download only active orders?"
    },
    {
      "name": "download_fills_page_size",
      "type": "std/uint32",
      "required": true,
      "default": 500,
      "description": "Page size used when downloading fills"
    },
    {
      "name": "download_fills_begin",
      "type": "std/nanoseconds",
      "validator": "roq/flags/validators/TimePeriod",
      "default": "24h",
      "description": "Download fills since (now - begin)"
    }
  ]
}
